# Pipeline Configuration
PIPELINE_JOB_ID=job-001
INPUT_PATH=/data/pipeline/job-001/input/video.mp4
OUTPUT_PATH=/data/pipeline/job-001/output/video.mp4

# FFmpeg — compiled from source (ffmpeg.org) in base Dockerfiles
# Both base-python and base-node compile the same FFmpeg version from source.
# Pin the version by changing FFMPEG_VERSION in both Dockerfiles' ARG.
FFMPEG_VERSION=7.1.1