{
  "name": "remotion-studio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "studio": "npx remotion studio",
    "server": "npx tsx src/server.ts",
    "dev": "npx tsx src/server.ts",
    "build:editor": "vite build src/editor --outDir ../../dist/editor",
    "dev:editor": "vite src/editor --port 5174",
    "start": "PORT=3123 npx tsx src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@remotion/bundler": "4.0.457",
    "@remotion/captions": "4.0.457",
    "@remotion/cli": "4.0.457",
    "@remotion/google-fonts": "4.0.457",
    "@remotion/player": "4.0.457",
    "@remotion/renderer": "4.0.457",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "react-router-dom": "^7.15.1",
    "remotion": "4.0.457"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^29.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.8"
  }
}
