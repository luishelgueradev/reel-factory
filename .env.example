# ─── Pipeline job ───────────────────────────────────────────────────────────
# Set per run by process.sh / the API server. Only needed for manual
# `docker compose run` invocations.
PIPELINE_JOB_ID=job-001
# INPUT_PATH / OUTPUT_PATH are container paths set per-step by the orchestrator.
INPUT_PATH=/data/pipeline/job-001/input/video.mp4
OUTPUT_PATH=/data/pipeline/job-001/output/video.mp4

# ─── Container file ownership ─────────────────────────────────────────────────
# docker-compose runs step containers as ${UID}:${GID} so files written into
# ./pipeline are owned by you. UID/GID are NOT exported by bash by default, so
# set them here (or `export UID=$(id -u) GID=$(id -g)` before docker compose).
UID=1000
GID=1000

# ─── Ports ────────────────────────────────────────────────────────────────────
API_PORT=3000
# remotion-studio MUST stay on 3123 (see AGENTS.md).
STUDIO_PORT=3123

# ─── API server / orchestration ───────────────────────────────────────────────
# Absolute HOST path to ./pipeline — the orchestrator bind-mounts it into sibling
# containers via the Docker socket, so it must be a host path. Defaults to
# $PWD/pipeline in compose; set explicitly if you run compose from elsewhere.
HOST_PIPELINE_DIR=
# Docker network the orchestrator attaches step containers to. Compose names it
# <project>_pipeline-net; default project is the repo directory name.
PIPELINE_NETWORK=reel-factory_pipeline-net
PROCESS_TIMEOUT_MS=600000
MAX_CONCURRENT_JOBS=2
MAX_BATCH_SIZE=10

# ─── Silence cutter tuning ─────────────────────────────────────────────────────
SILENCE_MIN_DURATION=0.5
SILENCE_CUT_SHRINK=0.4

# ─── Subtitle / render defaults (overridden by pipeline-config.json when present)
ACTIVE_COLOR=#FFFF00
INACTIVE_COLOR=#FFFFFF
FONT_SIZE=58

# ─── FFmpeg finalizer (9:16 output) ────────────────────────────────────────────
VERTICAL_WIDTH=1080
VERTICAL_HEIGHT=1920
CROP_STRATEGY=center

# ─── Build-time ────────────────────────────────────────────────────────────────
# FFmpeg is compiled from source in base-python and base-node Dockerfiles.
# Pin by changing the FFMPEG_VERSION ARG in both Dockerfiles.
FFMPEG_VERSION=7.1.1
